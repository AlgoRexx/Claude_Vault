{
  "watchDir": "~/Downloads",
  "projectStore": "~/Downloads/claude-vault/projects",
  "unlinkedStore": "~/Downloads/claude-vault/unlinked",
  "archiveDir": "~/Downloads/claude-vault/archive",
  "dbPath": "~/Downloads/claude-vault/claude_vault.db",
  "fileTypeAllowlist": [
    "csv", "json", "jsonl", "pdf", "png", "jpg", "txt", "py", "js", "ts", "md"
  ],
  "stabilizationThresholdMs": 2000,
  "pollIntervalMs": 500,
  "nearLimitThreshold": 20,
  "finalWindowThreshold": 30,
  "cleanupTtlDays": 30
}
